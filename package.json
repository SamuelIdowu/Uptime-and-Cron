{
  "name": "steady-state",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "pnpm --filter @steady-state/db db:studio",
    "test": "turbo run test:unit test:e2e"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "patchedDependencies": {
      "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
    }
  }
}
